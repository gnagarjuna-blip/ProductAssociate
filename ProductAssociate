            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.3: Systemic Pricing Engine Glitch]\nA currency conversion calculation error within an automated international repricing tool caused ASIN B04C7003KK to publish an active price of $0.05 instead of $500.00. High-frequency consumer scrapers placed thousands of orders before automated safety controls paused the listing, generating processing backlogs.\nTask: Outline the technical recovery steps to correct the pricing attributes, coordinate order cancellation approvals, and safely reactivate the catalog listing.", solution: "STRATEGIC EXECUTION: Enforce an immediate price hold lock on the listing page. Cancel pending orders flagged as data errors, correct the currency exchange valuation parameters, and safely unlock the detail page for public access." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.4: Brand Registry Hijack Remediation]\nA compromised high-tier vendor account changed administrative access permissions for an enrolled trademark group, removing the original brand owner and altering key product identifiers for high-velocity item ASIN B04C7004KK.\nTask: Formulate an emergency recovery plan to restore administrative access to the rightful brand owner and fix the modified catalog attributes.", solution: "STRATEGIC EXECUTION: Revoke the compromised vendor credentials and restore administrative access rights to the certified brand owner token. Reverse the unauthorized attribute modifications using verified historical backup files." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.5: Global ASIN Lockout Recovery]\nConflicting high-priority retail updates from two separate international operational hubs caused an administrative data deadlock, locking the catalog record for ASIN B04C7005KK and preventing any future inventory updates.\nTask: Explain the technical process to clear the data deadlock and restore normal edit permissions to the listing profile.", solution: "STRATEGIC EXECUTION: Use administrative database overrides to clear the data lock. Reset the configuration priority order across the conflicting regional hubs and re-index the canonical product record." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.6: Counterfeit Vector Suppression]\nAn organized fraud network bypassed standard security filters by using private listing invitations to distribute lookalike products under ASIN B04C7006KK, resulting in rising customer complaint rates.\nTask: Design a comprehensive screening protocol to identify shared account indicators among the fraudulent sellers and remove the unauthorized listings.", solution: "STRATEGIC EXECUTION: Deploy automated tracking scripts to identify related merchant accounts within the network. Terminate the unauthorized seller offers and restrict listing privileges to authorized brand distributors." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.7: Dangerous Goods Transport Compliance]\nPhysical safety inspections discovered that ASIN B04C7007KK contains active chemical compounds that require special shipping containers, contradicting the 'unrestricted' status listed in the catalog data.\nTask: Detail the immediate compliance steps required to update the catalog safety data and move the inventory to specialized storage facilities.", solution: "STRATEGIC EXECUTION: Update the product's hazard classification metadata to require dangerous goods handling. Pause regular shipping workflows and move the inventory to specialized Hazmat areas." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.8: Hazardous Material Inbound Discrepancy]\nFulfillment centers reported that shipments received for ASIN B04C7008KK feature pressurized canisters, although the catalog documentation describes the item as a non-pressurized liquid system.\nTask: Outline the safety containment steps and catalog correction flows required to resolve the product safety mismatch.", solution: "STRATEGIC EXECUTION: Place an immediate safety hold on the inbound inventory. Update the product classification record to reflect the pressurized safety profile and verify compliance documentation before releasing the hold." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.9: Duplicate Parent Consolidation]\nMultiple independent distributors generated separate parent variation structures for the same product line, resulting in fragmented customer reviews and confused search rankings for ASIN B04C7009KK.\nTask: Outline the catalog merging workflow to consolidate the separate variation trees into a single, clean canonical listing structure.", solution: "STRATEGIC EXECUTION: Select the authentic brand-created parent node as the canonical listing structure. Merge the duplicate variation entries into the target family and clean the search index mappings." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.10: Review Invalidation and Splitting]\nAn unauthorized parent-child listing merge combined the user reviews of an inexpensive accessory item with a premium electronics item under ASIN B04C7010KK, manipulating the product rating metrics.\nTask: Detail the data remediation steps required to split the incorrect relationship and assign the historical reviews back to their respective items.", solution: "STRATEGIC EXECUTION: Break the incorrect parental variation relationship. Separate historical customer reviews using product transaction identifiers and re-index both product profiles independently." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.11: Restricted Ingredient Deep Purge]\nNew public health guidelines added an active herb used in dietary supplement ASIN B04C7011KK to the restricted substances registry, requiring immediate removal from the active marketplace catalog.\nTask: Map out the global de-indexing steps required to remove the restricted product from all regional storefront locations.", solution: "STRATEGIC EXECUTION: Implement an un-appealable global product suppression flag on the ASIN. Remove the listing from active search indexes and initiate inventory disposal workflows for fulfillment center stock." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.12: Automated Image Hijack Override]\nA legacy data exchange vulnerability allowed an unverified external data feed to replace the primary product images of high-traffic listing ASIN B04C7012KK with low-quality promotional banners.\nTask: Detail the recovery steps to secure the image configuration variables and restore the original brand asset links.", solution: "STRATEGIC EXECUTION: Revert the image configuration pointers to the verified brand asset directory. Terminate the legacy data feed access privileges and restrict image modification rights to the brand owner." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.13: Bulk Listing Metadata Correction]\nA corrupted spreadsheet ingestion payload altered the manufacturing part numbers for 500 active hardware items under parent ASIN B04C7013KK, breaking downstream warehouse picking routing lines.\nTask: Formulate an automated correction pipeline to parse verified manufacturer data files and fix the broken catalog records.", solution: "STRATEGIC EXECUTION: Ingest the verified manufacturer reference data file via the High-Priority Update Utility. Overwrite the broken part number fields and verify downstream warehouse system synchronization." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.14: UPC Exclusivity Mapping Realignment]\nAn administrative data entry error assigned a single exclusive UPC barcode to two entirely different consumer electronics items, generating severe inventory tracking conflicts for ASIN B04C7014KK.\nTask: Explain the technical isolation steps required to separate the conflicting product records and map them to their distinct barcodes.", solution: "STRATEGIC EXECUTION: Create a new separate product identifier entry within the catalog database. Re-map the conflicting items to their authentic verified barcodes and clear the inventory tracking logs." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.15: Parallel Import Exclusion Sweep]\nAuthorized brand networks flagged ASIN B04C7015KK for distributing international variations of a product inside a territory where it lacks the necessary regional certification approvals.\nTask: Map out the geographical filtering rules required to restrict the listing access to compliant regions within the catalog engine.", solution: "STRATEGIC EXECUTION: Implement strict country-code shipping restrictions on the product record. Suppress non-certified merchant offers from the regional storefront and verify local compliance parameters." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.16: Traceability Token Validation]\nAn audit of luxury cosmetic item ASIN B04C7016KK revealed that an unverified reseller network modified the product descriptions to remove required traceability batch data fields.\nTask: Outline the enforcement actions required to restore the mandatory compliance fields and verify reseller documentation authenticity.", solution: "STRATEGIC EXECUTION: Lock the listing description fields to the verified brand owner configuration. Require active resellers to present authentic invoice documentation or face offer suppression." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.17: Expired Product Risk Assessment]\nCustomer feedback logs for grocery item ASIN B04C7017KK showed a rising frequency of complaints regarding expired products, indicating a failure in fulfillment center rotational sweeping filters.\nTask: Design an automated quality gate within the catalog metadata to require explicit expiration tracking parameters for the item family.", solution: "STRATEGIC EXECUTION: Turn on the mandatory expiration tracking flag within the product category metadata schema. Put the listing on a temporary hold until fulfillment centers verify active date codes." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.18: Text Layout Deserialization Patch]\nA structural system error corrupted the product detail page formatting for ASIN B04C7018KK, rendering the text description as unreadable raw binary code lines for public users.\nTask: Detail the technical recovery steps to fix the corrupted text fields and force a clean re-rendering of the product page layout.", solution: "STRATEGIC EXECUTION: Run a data repair routine to replace the corrupted text fields with verified plain text backups. Flush the database caching layer to update the public product page display." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.19: Search Index Suppression Rollback]\nAn over-aggressive security keyword filter mistakenly flagged high-volume listing ASIN B04C7019KK for policy violations, removing it from public search results.\nTask: Walk through the verification process to audit the automated flag, clear the false positive block, and re-index the product listing.", solution: "STRATEGIC EXECUTION: Review the triggered keyword rule manually to confirm the false positive status. Deactivate the security block and initiate a full search engine index crawl for the ASIN." },
            { text: "[BRAND INTEGRITY COMPLEX STUDY #4.20: Pesticide False Positive Resolution]\nAn apparel product listing (ASIN B04C7020KK) was automatically suppressed by safety filters because the product title included the text string 'antimicrobial protection', misclassifying it as a pesticide device.\nTask: Detail the remediation steps to update the descriptive terminology and clear the regulatory suppression flag.", solution: "STRATEGIC EXECUTION: Modify the listing text to use approved general descriptive terminology that satisfies style guides. Clear the automated pesticide device flag to restore standard page visibility." }
        ];

        // --- DAY 5: EXAM QUESTIONS ---
        const examQuestionsData = [
            { q: "A seller merges a listing for a discontinued charging cable with a highly rated wireless mouse to borrow its reviews. How should a Product Associate categorize this violation?", o: ["Product Type Misclassification", "Variation Abuse (ASIN Twisting)", "Intellectual Property Infringement", "Hazmat Safety Deviation"], a: 1 },
            { q: "An automated feed from an external vendor overrides an enrolled brand's product image with incorrect formatting. What internal mechanic should be executed to solve this?", o: ["Delete the ASIN completely", "Reduce the seller's contribution score and lock attribute mapping to the Brand Registry token", "Initiate a physical warehouse audit", "Approve a global GL string migration"], a: 1 },
            { q: "A listing is flagged for containing unauthorized therapeutic claims under federal drug regulations. What immediate action must be taken?", o: ["Suppress the ASIN and route to the Restricted Products Team for review", "Email the seller asking them to change the text within 14 days", "Change the category allocation to Home Goods", "Merge the ASIN into a parent family"], a: 0 },
            { q: "Which tool should be utilized to correct historical review mappings when an unauthorized parent-child relationship is dismantled?", o: ["FBA Inventory Management Console", "Category Cleanup and ASIN Disruption Manager", "Brand Registry Authorization Matrix", "Dynamic Currency Conversion Switchboard"], a: 1 },
            { q: "What is the primary indicator that a listing has suffered an attribute ownership hijack?", o: ["FBA storage fees increase suddenly", "Customer reviews drop to 0 stars", "The Detail Page contribution shifts from the Brand Owner to an unverified third-party merchant token", "The ASIN matches exactly with another duplicate identifier"], a: 2 }
        ];

        // ==================== APPLICATION CONTROLLER FRAMEWORK ====================

        window.addEventListener("DOMContentLoaded", () => {
            loadSavedProgressState();
            renderAllSectionsDOM();
            calculateGlobalProgress();
            restoreActiveTabState();
            setupAntiCheatFramework();
        });

        function renderAllSectionsDOM() {
            // Day 1 Cases
            const d1cBin = document.getElementById("day1-cases-bin");
            d1CasesData.forEach((item, index) => {
                const isComp = moduleTrackingState.day1_cases[index];
                d1cBin.appendChild(createCaseCard("day1_cases", index, item.text, item.solution, isComp));
            });

            // Day 1 Drills
            const d1dBin = document.getElementById("day1-drills-bin");
            d1DrillsData.forEach((item, index) => {
                const isComp = moduleTrackingState.day1_drills[index];
                d1dBin.appendChild(createDrillCard("day1_drills", index, item.text, isComp));
            });

            // Day 2 Drills
            const d2dBin = document.getElementById("day2-drills-bin");
            d2DrillsData.forEach((item, index) => {
                const isComp = moduleTrackingState.day2[index];
                d2dBin.appendChild(createDrillCard("day2", index, item.text, isComp));
            });

            // Day 3 Drills
            const d3dBin = document.getElementById("day3-drills-bin");
            d3DrillsData.forEach((item, index) => {
                const isComp = moduleTrackingState.day3[index];
                d3dBin.appendChild(createDrillCard("day3", index, item.text, isComp));
            });

            // Day 4 Cases
            const d4cBin = document.getElementById("day4-cases-bin");
            d4CasesData.forEach((item, index) => {
                const isComp = moduleTrackingState.day4[index];
                d4cBin.appendChild(createCaseCard("day4", index, item.text, item.solution, isComp));
            });
        }

        function createCaseCard(moduleKey, index, text, solution, isCompleted) {
            const card = document.createElement("div");
            card.className = `static-case-item ${isCompleted ? 'completed' : ''}`;
            card.id = `card-${moduleKey}-${index}`;
            card.innerHTML = `
                <div class="case-text">${text}</div>
                <div class="static-solution-block"><strong>RECOMMENDED MITIGATION OUTLINE:</strong><br>${solution}</div>
                <div style="margin-top:20px; text-align:right;">
                    <button class="submit-item-btn ${isCompleted ? 'done' : ''}" 
                            id="btn-${moduleKey}-${index}" 
                            onclick="markCaseAsRead('${moduleKey}', ${index})">
                        ${isCompleted ? '✓ Analyzed & Completed' : 'Acknowledge Case Review'}
                    </button>
                </div>
            `;
            return card;
        }

        function createDrillCard(moduleKey, index, text, isCompleted) {
            const card = document.createElement("div");
            card.className = `drill-item ${isCompleted ? 'completed' : ''}`;
            card.id = `card-${moduleKey}-${index}`;
            const inputVal = textInputsState[`${moduleKey}-${index}`] || "";
            card.innerHTML = `
                <div class="drill-text">${text}</div>
                <textarea class="solution-box" id="input-${moduleKey}-${index}" 
                          placeholder="Type your strategic analysis and specific corrective step sequence here..." 
                          ${isCompleted ? 'disabled' : ''} oninput="cacheTextInput('${moduleKey}', ${index})">${inputVal}</textarea>
                <div style="text-align:right;">
                    <button class="submit-item-btn ${isCompleted ? 'done' : ''}" 
                            id="btn-${moduleKey}-${index}" 
                            onclick="submitDrillVerification('${moduleKey}', ${index})">
                        ${isCompleted ? '✓ Logic Verified' : 'Submit Diagnostic Resolution'}
                    </button>
                </div>
            `;
            return card;
        }

        function markCaseAsRead(moduleKey, index) {
            if(moduleTrackingState[moduleKey][index]) return;
            moduleTrackingState[moduleKey][index] = true;
            document.getElementById(`card-${moduleKey}-${index}`).classList.add("completed");
            const btn = document.getElementById(`btn-${moduleKey}-${index}`);
            btn.classList.add("done");
            btn.innerText = "✓ Analyzed & Completed";
            saveProgressToStorage();
            calculateGlobalProgress();
        }

        function cacheTextInput(moduleKey, index) {
            const val = document.getElementById(`input-${moduleKey}-${index}`).value;
            textInputsState[`${moduleKey}-${index}`] = val;
            localStorage.setItem(STORAGE_TEXT_KEY, JSON.stringify(textInputsState));
        }

        function submitDrillVerification(moduleKey, index) {
            if(moduleTrackingState[moduleKey][index]) return;
            const textVal = document.getElementById(`input-${moduleKey}-${index}`).value.trim();
            if(textVal.length < 15) {
                alert("Validation Exception: Your resolution details are insufficient. Please supply a thorough operational process plan to ensure catalog safety.");
                return;
            }
            moduleTrackingState[moduleKey][index] = true;
            document.getElementById(`card-${moduleKey}-${index}`).classList.add("completed");
            document.getElementById(`input-${moduleKey}-${index}`).disabled = true;
            const btn = document.getElementById(`btn-${moduleKey}-${index}`);
            btn.classList.add("done");
            btn.innerText = "✓ Logic Verified";
            saveProgressToStorage();
            calculateGlobalProgress();
        }

        function calculateGlobalProgress() {
            const weights = { day1_cases: 20, day1_drills: 25, day2: 25, day3: 25, day4: 20 };
            let totalItems = 0, completedItems = 0;

            for (let key in weights) {
                totalItems += weights[key];
                completedItems += moduleTrackingState[key].filter(Boolean).length;
            }

            const globalPercent = Math.round((completedItems / totalItems) * 100);
            document.getElementById("master-progress-bar").style.width = `${globalPercent}%`;

            // Individual badges
            const d1Comp = moduleTrackingState.day1_cases.filter(Boolean).length + moduleTrackingState.day1_drills.filter(Boolean).length;
            document.getElementById("badge-day1").innerText = `${Math.round((d1Comp / 45) * 100)}%`;
            document.getElementById("badge-day2").innerText = `${Math.round((moduleTrackingState.day2.filter(Boolean).length / 25) * 100)}%`;
            document.getElementById("badge-day3").innerText = `${Math.round((moduleTrackingState.day3.filter(Boolean).length / 25) * 100)}%`;
            document.getElementById("badge-day4").innerText = `${Math.round((moduleTrackingState.day4.filter(Boolean).length / 20) * 100)}%`;

            // Day 5 unlock check
            const examBtn = document.getElementById("btn-day5");
            if(globalPercent === 100) {
                examBtn.classList.remove("locked");
                examBtn.disabled = false;
                examBtn.innerHTML = "Day 5: Certification Exam 🔓";
            } else {
                examBtn.classList.add("locked");
                examBtn.disabled = true;
                examBtn.innerHTML = "Day 5: Certification Exam 🔐";
            }
        }

        function navigateToSection(sectionId) {
            document.querySelectorAll(".day-section").forEach(s => s.classList.remove("active"));
            document.querySelectorAll(".day-btn").forEach(b => b.classList.remove("active"));
            document.getElementById(sectionId).classList.add("active");
            
            const targetBtnId = "btn-" + sectionId.split("-")[0];
            const targetBtn = document.getElementById(targetBtnId);
            if(targetBtn) targetBtn.classList.add("active");

            localStorage.setItem(STORAGE_TAB_KEY, sectionId);
            document.getElementById("main-viewport").scrollTop = 0;
        }

        function restoreActiveTabState() {
            const savedTab = localStorage.getItem(STORAGE_TAB_KEY);
            if (savedTab && document.getElementById(savedTab)) {
                navigateToSection(savedTab);
            }
        }

        function saveProgressToStorage() {
            localStorage.setItem(STORAGE_STATE_KEY, JSON.stringify(moduleTrackingState));
        }

        function loadSavedProgressState() {
            const stored = localStorage.getItem(STORAGE_STATE_KEY);
            if(stored) moduleTrackingState = JSON.parse(stored);
            const txts = localStorage.getItem(STORAGE_TEXT_KEY);
            if(txts) textInputsState = JSON.parse(txts);
        }

        function clearSavedProgress() {
            if(confirm("Are you sure you want to completely flush your current Amazon competency training metrics? All input summaries will be deleted.")) {
                localStorage.clear();
                window.location.reload();
            }
        }

        // --- SECURITY AND PROCTORED TESTING SYSTEM ---
        let cheatCheckActive = false;

        function setupAntiCheatFramework() {
            window.addEventListener("blur", () => {
                if(cheatCheckActive) triggerSecurityTermination();
            });
            document.addEventListener("visibilitychange", () => {
                if(document.visibilityState === 'hidden' && cheatCheckActive) {
                    triggerSecurityTermination();
                }
            });
        }

        function triggerExamLaunchSequence() {
            document.getElementById("exam-instructions-modal").style.display = "flex";
        }

        function launchProctoredExamViewport() {
            document.getElementById("exam-instructions-modal").style.display = "none";
            document.getElementById("secure-exam-overlay").style.display = "block";
            
            const bodyElem = document.documentElement;
            if (bodyElem.requestFullscreen) bodyElem.requestFullscreen();
            
            renderExamQuestions();
            setTimeout(() => { cheatCheckActive = true; }, 1000);
        }

        function renderExamQuestions() {
            const form = document.getElementById("proctored-exam-form");
            form.innerHTML = "";
            examQuestionsData.forEach((qObj, qIdx) => {
                const card = document.createElement("div");
                card.className = "exam-question-card";
                card.innerHTML = `
                    <div class="exam-question-text">Question ${qIdx + 1}: ${qObj.q}</div>
                    <div id="options-group-${qIdx}">
                        ${qObj.o.map((opt, oIdx) => `
                            <label class="exam-option-wrapper">
                                <input type="radio" name="question-${qIdx}" value="${oIdx}" style="margin-right:12px;"> ${opt}
                            </label>
                        `).join('')}
                    </div>
                `;
                form.appendChild(card);
            });
        }

        function evaluateExamSubmission() {
            cheatCheckActive = false;
            let correctCount = 0;
            examQuestionsData.forEach((qObj, qIdx) => {
                const selected = document.querySelector(`input[name="question-${qIdx}"]:checked`);
                if(selected && parseInt(selected.value) === qObj.a) {
                    correctCount++;
                }
            });

            const scorePercent = (correctCount / examQuestionsData.length) * 100;
            if(document.exitFullscreen) document.exitFullscreen().catch(()=>{});

            document.getElementById("secure-exam-overlay").style.display = "none";

            if(scorePercent >= 80) {
                alert(`🎉 Congratulations! You achieved a score of ${scorePercent}% on the competency metrics matrix. Your specialized Amazon Product Associate credentials have been assigned.`);
            } else {
                alert(`❌ Competency threshold not met. Your current calculation is ${scorePercent}%. The passing limit is 80%. Please try again.`);
            }
            window.location.reload();
        }

        function triggerSecurityTermination() {
            cheatCheckActive = false;
            document.getElementById("secure-exam-overlay").style.display = "none";
            document.getElementById("exam-instructions-modal").style.display = "none";
            document.getElementById("cheat-lockout-screen").style.display = "flex";
            if(document.exitFullscreen) document.exitFullscreen().catch(()=>{});
        }
    </script>
</body>
</html>
